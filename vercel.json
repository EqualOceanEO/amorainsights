{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "installCommand": "npm install --legacy-peer-deps",
  "regions": ["sin1"],
  "git": {
    "deploymentEnabled": {
      "master": true
    }
  },
  "crons": [
    {
      "path": "/api/admin/auto-migrate?secret=run-migration-now",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/admin/news-generator?secret=run-migration-now",
      "schedule": "0 6 * * *"
    }
  ]
}
